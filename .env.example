# PostgreSQL (checkpoints + artifacts metadata)
PG_CONNECTION_STRING=

# Telegram (approval interrupts). Required for Docker app; create .env from this file and set your token.
TELEGRAM_BOT_TOKEN=

# Ollama (local LLM for Phase 1+ AI-powered analysis)
# Use host.docker.internal from Docker, or localhost if running locally
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b
# Seconds to wait for Ollama response; first request after start is often slow (model load). Default 300.
OLLAMA_TIMEOUT=300
# Context window size (tokens). Lower = less RAM; 4096 default. Set 0 to use model default (can be 128k = high memory).
OLLAMA_NUM_CTX=4096
# Max CPU threads per Ollama request. 0 = Ollama default. Set e.g. 4 to cap CPU usage.
OLLAMA_NUM_THREAD=4

# Google Stitch (Phase 3 - UI/UX Design generation)
# Supports EITHER API key (REST) OR service account (MCP).
# For automatic design (no manual copy-paste): set GOOGLE_STITCH_API_KEY or GOOGLE_SERVICE_ACCOUNT_PATH.

# Option 1: API Key (REST) - recommended for Docker; required for Phase 3 auto-generation (link + screenshots in Telegram)
GOOGLE_STITCH_API_KEY=
# Base URL for Stitch REST API; if 404/connection errors, check Stitch docs for the correct API base and set here.
GOOGLE_STITCH_BASE_URL=https://stitch.google.com

# Option 2: Service Account (MCP) - use if you prefer GCP service account; in Docker set path inside container, e.g. /app/secrets/project-xxx.json
# GOOGLE_SERVICE_ACCOUNT_PATH=/absolute/path/to/your-service-account.json

GOOGLE_STITCH_TIMEOUT=120
GOOGLE_STITCH_ENABLED=true

# Product generation (Phase 5/7: CliMobile + DriveShield user-zone). Default false for deterministic CI/tests.
# PRODUCT_GEN_ENABLED=false
